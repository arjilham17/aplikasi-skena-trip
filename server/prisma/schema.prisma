datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String?
  googleId  String?   @unique
  role      String    @default("customer") // 'customer' or 'admin'
  address   String?
  gender    String?
  whatsapp  String?
  profilePicUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  logs      ActivityLog[]
  reviews   Review[]
}

model Trip {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  destination String
  date        DateTime
  price       Float
  quota       Int
  image       String?
  imagePosition String? @default("center")
  duration    String?
  rating      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  expenses    Expense[]
  reviews     Review[]
  itinerary   ItineraryItem[]
}

model Booking {
  id          Int       @id @default(autoincrement())
  userId      Int
  tripId      Int
  pax         Int
  totalPrice  Float
  promoCode   String?
  status      String    @default("pending") // pending, confirmed, cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  trip        Trip      @relation(fields: [tripId], references: [id])
  payments    Payment[]
}

model Payment {
  id            Int       @id @default(autoincrement())
  bookingId     Int
  amount        Float
  method        String
  proofUrl      String?
  status        String    @default("unpaid") // unpaid, pending_verification, paid
  paymentDate   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  booking       Booking   @relation(fields: [bookingId], references: [id])
}

model Expense {
  id          Int       @id @default(autoincrement())
  tripId      Int
  itemName    String
  category    String
  amount      Float
  receiptUrl  String?
  expenseDate DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trip        Trip      @relation(fields: [tripId], references: [id])
}

model PromoCode {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  discountAmount  Float
  discountType    String   @default("flat") // "flat" or "percentage"
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id               Int      @id @default(1)
  siteName         String   @default("Skena Trip")
  slogan           String   @default("Teman Perjalanan Skena Kamu")
  logoUrl          String?
  heroTitle        String   @default("Temukan Petualangan Skena Kamu")
  heroSubtitle     String   @default("Jelajahi destinasi tersembunyi dengan gaya hidup skena yang autentik.")
  heroImages       HeroImage[]
  contactEmail     String?  @default("info@skenatrip.com")
  contactPhone     String?  @default("08123456789")
  address          String?  @default("Jakarta, Indonesia")
  expenseThreshold Float    @default(1000000) // Default 1jt
  updatedAt        DateTime @updatedAt
}

model HeroImage {
  id             Int          @id @default(autoincrement())
  url            String
  siteSettingsId Int
  siteSettings   SiteSettings @relation(fields: [siteSettingsId], references: [id])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model AdminNotification {
  id        Int      @id @default(autoincrement())
  type      String   // 'DELETION', 'HIGH_EXPENSE', etc.
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String
  imageUrl  String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id])
  createdAt DateTime @default(now())
}

model ItineraryItem {
  id          Int      @id @default(autoincrement())
  time        String
  activity    String
  description String?
  tripId      Int
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
